{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "grammar": {
          "complex_attempts": {
            "$attemptId": {
              ".write": "auth != null && (auth.uid === $uid || auth.token.email === 'azimjonxolmirzayev30@gmail.com')"
            }
          }
        }
      }
    },
    "grammar_pending_attempts": {
      ".read": "auth != null && auth.token.email === 'azimjonxolmirzayev30@gmail.com'",
      "$attemptId": {
        ".write": "auth != null && (auth.token.email === 'azimjonxolmirzayev30@gmail.com' || (!data.exists() && newData.child('userId').val() === auth.uid))"
      }
    }
  }
}
